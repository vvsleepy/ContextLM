{
  "name": "doc-buddy-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Zero-Cost NotebookLM Clone",
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build --workspaces",
    "start": "npm run start --workspaces"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
